# https://editorconfig.org — baseline so every editor agrees before Prettier runs.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
# Keep trailing whitespace in Markdown (two spaces = hard line break).
trim_trailing_whitespace = false

[*.{sh,bash}]
indent_size = 2

[Makefile]
indent_style = tab
