{
  "name": "sk-video",
  "version": "1.0.0",
  "description": "SK Video — a Signal K plugin that turns IP cameras (RTSP/RTMP/ONVIF) into browser-playable streams for KIP, with ONVIF PTZ, discovery and video uploads.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.16.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "dev:link": "scripts/dev-link.sh",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "node scripts/prepare.mjs",
    "prepublishOnly": "npm run build"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "commit-msg": "npx --no-install commitlint --edit \"$1\""
  },
  "lint-staged": {
    "*.{ts,js,cjs,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-category-utility",
    "ip-camera",
    "rtsp",
    "onvif",
    "go2rtc",
    "video",
    "kip"
  ],
  "author": "Dillan Laughlin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dillan/sk-video.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/js": "^9.13.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@signalk/server-api": "^2.22.0",
    "@types/adm-zip": "^0.5.8",
    "@types/express": "^5.0.6",
    "@types/multicast-dns": "^7.2.4",
    "@types/node": "^20.16.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.13.0",
    "globals": "^15.11.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.3.3",
    "semantic-release": "^25.0.5",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.10.0",
    "vitest": "^2.1.3"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "multicast-dns": "^7.2.5",
    "onvif": "^0.8.1"
  }
}
